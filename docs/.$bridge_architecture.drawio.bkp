        <mxCell id="osm3N-SdJkY_QjZSTnFf-30" value="Network async thread" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
