        </mxCell>
        <mxCell id="osm3N-SdJkY_QjZSTnFf-4" value="Raw network sockets" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="720" width="320" height="40" as="geometry" />
        </mxCell>
        <mxCell id="osm3N-SdJkY_QjZSTnFf-5" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Network Threads&lt;/h1&gt;&lt;p&gt;Listen to multiple sockets. Need to record the protocol (socket) interface and source address because it could be using link-local. This is stored as the device address&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="180" y="540" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="osm3N-SdJkY_QjZSTnFf-6" value="" style="endArrow=classic;startArrow=classic;html=1;rounded=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;exitX=0.5;exitY=0;exitDx=0;exitDy=0;" edge="1" parent="1" source="osm3N-SdJkY_QjZSTnFf-4" target="osm3N-SdJkY_QjZSTnFf-1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="560" y="660" as="sourcePoint" />
            <mxPoint x="610" y="610" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="osm3N-SdJkY_QjZSTnFf-7" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;Network async threads.&lt;/font&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 8px;&quot;&gt;Listen to network, get zero or one response&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 8px;&quot;&gt;Events from the stack - how to select/send. If we send a request, should we wait for a response... Let&#39;s assume that outbound requests are not sent to multicast? But what about notification events? Do we need to classify into response expected/not expected?&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="530" y="570" width="190" height="70" as="geometry" />
        </mxCell>
        <mxCell id="osm3N-SdJkY_QjZSTnFf-8" value="Raw Serial devices" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="720" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="osm3N-SdJkY_QjZSTnFf-9" value="" style="endArrow=classic;startArrow=classic;html=1;rounded=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;exitX=0.5;exitY=0;exitDx=0;exitDy=0;" edge="1" parent="1" source="osm3N-SdJkY_QjZSTnFf-8" target="osm3N-SdJkY_QjZSTnFf-2">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="530" y="730" as="sourcePoint" />
            <mxPoint x="530" y="490" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="osm3N-SdJkY_QjZSTnFf-10" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;USB async threads.&lt;/font&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;font-size: 8px;&quot;&gt;Do have events coming from both sides. Assume no bridge between socket and USB.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="810" y="570" width="190" height="70" as="geometry" />
        </mxCell>
        <mxCell id="osm3N-SdJkY_QjZSTnFf-11" value="Only route-b supported" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="810" y="498" width="150" height="30" as="geometry" />
        </mxCell>
        <mxCell id="osm3N-SdJkY_QjZSTnFf-12" value="Echonet Lite Wire" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="360" width="520" height="40" as="geometry" />
        </mxCell>
        <mxCell id="osm3N-SdJkY_QjZSTnFf-13" value="Filter non-echonet data here" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="880" y="440" width="170" height="30" as="geometry" />
        </mxCell>
        <mxCell id="osm3N-SdJkY_QjZSTnFf-14" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;USB Threads&lt;/h1&gt;&lt;p&gt;Listen to multiple sockets. Need to record the protocol (serial), device and source address because it could be using link-local. This is stored as the device address&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1010" y="540" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="osm3N-SdJkY_QjZSTnFf-15" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Wire adapter&lt;/h1&gt;&lt;p&gt;Turns middleware events and changes into routed ECHONET Lite wire data to be sent.&amp;nbsp; Can be in response to a request, or initiated though an announcement.&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="900" y="320" width="280" height="110" as="geometry" />
        </mxCell>
        <mxCell id="osm3N-SdJkY_QjZSTnFf-16" value="Echonet Lite Middleware" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="120" width="520" height="200" as="geometry" />
        </mxCell>
        <mxCell id="osm3N-SdJkY_QjZSTnFf-17" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Middleware&lt;/h1&gt;&lt;p&gt;Stores the state data. Has both the own device nodes (profile and controller class), and a copy of each node&#39;s current state/capabilities (general vs tx; which operations are supported; booting etc), the address, and last data?&lt;/p&gt;&lt;p&gt;When a device announces/registers, then query the supported classes. What about devices that have announced before we joined the network?&lt;/p&gt;&lt;p&gt;In general, state changes from the echonet side should push events to the Home Assistant side, and visa versa&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="910" y="100" width="380" height="210" as="geometry" />
        </mxCell>
        <mxCell id="osm3N-SdJkY_QjZSTnFf-18" value="" style="endArrow=classic;startArrow=classic;html=1;rounded=0;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.308;entryY=1;entryDx=0;entryDy=0;entryPerimeter=0;strokeColor=default;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=11;fontColor=default;labelBackgroundColor=default;" edge="1" parent="1" source="osm3N-SdJkY_QjZSTnFf-1" target="osm3N-SdJkY_QjZSTnFf-12">
